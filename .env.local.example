# Local authoring/practice — required only when running locally
LOCAL_MODE=1
# Local data lives in a SQLite file (default below). Leave Turso vars unset
# locally; the app falls back to file:local.db.

# Cloud (deployed on Vercel) — required there
# Provided automatically by the Turso Cloud Vercel integration:
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-token
# GitHub OAuth gate (cloud only):
GITHUB_ID=
GITHUB_SECRET=
ALLOWED_GITHUB_LOGIN=your-github-username
AUTH_SECRET=generate-a-long-random-string
# AUTH_URL is auto-detected on Vercel; set it for local/custom hosts.
AUTH_URL=http://localhost:3000
